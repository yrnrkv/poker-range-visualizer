datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Range {
  id        String   @id @default(uuid())
  name      String
  position  String?
  hands     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
